<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/digit_color"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- ── Weather ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Weather"
            android:textColor="@color/hindu_gold"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="City (e.g. Mumbai, IN)"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etApiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="OpenWeatherMap API Key"
                android:textColor="@color/white"
                android:inputType="textVisiblePassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Get a free API key at openweathermap.org"
            android:textColor="#777777"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <!-- Temperature Units -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Temperature Units"
                android:textColor="@color/date_color"
                android:textSize="14sp" />

            <RadioGroup
                android:id="@+id/rgUnits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbCelsius"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="°C"
                    android:textColor="@color/date_color"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbFahrenheit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="°F"
                    android:textColor="@color/date_color"
                    android:layout_marginStart="16dp" />

            </RadioGroup>
        </LinearLayout>

        <!-- ── Sound ── -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginVertical="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sound"
            android:textColor="@color/hindu_gold"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Quarter-hour chimes (:00 :15 :30 :45)"
                android:textColor="@color/date_color"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/cbChimes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chime Style"
            android:textColor="@color/date_color"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerChime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:backgroundTint="@color/date_color" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPreviewChime"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preview Chime"
            android:textSize="13sp" />

        <!-- ── Colors ── -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginVertical="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Colors"
            android:textColor="@color/hindu_gold"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap a swatch to pick a color, or type a hex code (#RRGGBB)"
            android:textColor="#777777"
            android:textSize="11sp"
            android:layout_marginBottom="14dp" />

        <!-- Flip Clock Digits -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Flip Clock Digits"
                android:textColor="@color/date_color"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etColorClock"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:hint="#FFAA00"
                android:textColor="@color/white"
                android:inputType="text"
                android:maxLength="7" />

            <View
                android:id="@+id/vSwatchClock"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Panchang Text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Panchang Text"
                android:textColor="@color/date_color"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etColorPanchang"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:hint="#FFD700"
                android:textColor="@color/white"
                android:inputType="text"
                android:maxLength="7" />

            <View
                android:id="@+id/vSwatchPanchang"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Date / Secondary Text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Date / Info Text"
                android:textColor="@color/date_color"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etColorDate"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:hint="#CCCCCC"
                android:textColor="@color/white"
                android:inputType="text"
                android:maxLength="7" />

            <View
                android:id="@+id/vSwatchDate"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Weather Text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Weather Text"
                android:textColor="@color/date_color"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etColorWeather"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:hint="#87CEEB"
                android:textColor="@color/white"
                android:inputType="text"
                android:maxLength="7" />

            <View
                android:id="@+id/vSwatchWeather"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save &amp; Apply"
            android:textSize="16sp"
            android:layout_marginBottom="40dp" />

    </LinearLayout>
</ScrollView>
